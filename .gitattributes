# Normalize line endings: text files are stored with LF in the repo
* text=auto

# Documentation and config — always LF in repo
*.md text eol=lf
*.txt text eol=lf
*.cfg text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Godot project files — always LF in repo
*.gd text eol=lf
*.tscn text eol=lf
*.tres text eol=lf
*.import text eol=lf
*.godot text eol=lf
*.shader text eol=lf
*.gdshader text eol=lf

# Binary assets — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg text eol=lf
*.wav binary
*.mp3 binary
*.ogg binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.zip binary
*.pdf binary
